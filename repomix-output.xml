import { createContext, useContext, useState, useEffect, ReactNode } from 'react';

export type Theme = 'branco' | 'preto' | 'kamba';

interface AppSettings {
  dataSaver: boolean;
  setDataSaver: (value: boolean) => void;
  theme: Theme;
  setTheme: (value: Theme) => void;
}

const AppContext = createContext<AppSettings | null>(null);

const STORAGE_KEY = 'kazakamba_settings';

function applyTheme(theme: Theme) {
  const root = document.documentElement;
  root.setAttribute('data-theme', theme);
  const metaThemeColor = document.querySelector('meta[name="theme-color"]');
  if (metaThemeColor) {
    const colors: Record<Theme, string> = {
      branco: '#F8FAFC',
      preto: '#0A192F',
      kamba: '#1A1A2E',
    };
    metaThemeColor.setAttribute('content', colors[theme]);
  }
}

export function AppProvider({ children }: { children: ReactNode }) {
  const [dataSaver, setDataSaverState] = useState(false);
  const [theme, setThemeState] = useState<Theme>('preto');

  useEffect(() => {
    const stored = localStorage.getItem(STORAGE_KEY);
    if (stored) {
      try {
        const parsed = JSON.parse(stored);
        setDataSaverState(parsed.dataSaver || false);
        if (parsed.theme && ['branco', 'preto', 'kamba'].includes(parsed.theme)) {
          setThemeState(parsed.theme);
        }
      } catch {
        // Ignore parse errors
      }
    }
  }, []);

  useEffect(() => {
    applyTheme(theme);
  }, [theme]);

  const setDataSaver = (value: boolean) => {
    setDataSaverState(value);
    const stored = localStorage.getItem(STORAGE_KEY);
    const parsed = stored ? JSON.parse(stored) : {};
    localStorage.setItem(STORAGE_KEY, JSON.stringify({ ...parsed, dataSaver: value }));
  };

  const setTheme = (value: Theme) => {
    setThemeState(value);
    const stored = localStorage.getItem(STORAGE_KEY);
    const parsed = stored ? JSON.parse(stored) : {};
    localStorage.setItem(STORAGE_KEY, JSON.stringify({ ...parsed, theme: value }));
  };

  return (
    <AppContext.Provider value={{ dataSaver, setDataSaver, theme, setTheme }}>
      {children}
    </AppContext.Provider>
  );
}

export function useAppSettings() {
  const context = useContext(AppContext);
  if (!context) {
    throw new Error('useAppSettings must be used within AppProvider');
  }
  return context;
}
